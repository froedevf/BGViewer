<?xml version="1.0" encoding="utf-8" ?>
<!--
  MainScene - setup-only shell for the BGViewer channel.

  BGViewer's data display is provided exclusively by its registered
  screensaver (ScreensaverScene), per Roku platform policy (rule 4.5:
  channels may not offer in-channel screensavers or override the
  system screensaver).

  This scene only handles:
    - First-run medical disclaimer
    - Account configuration (SettingsScene)
    - A post-setup instruction screen that tells the user how to
      enable the screensaver in Roku settings.
-->
<component name="MainScene" extends="Scene">
  <script type="text/brightscript" uri="pkg:/source/RegistryUtils.brs" />
  <script type="text/brightscript" uri="pkg:/components/MainScene.brs" />
  <children>

    <Rectangle id="bg" width="1920" height="1080" color="#000000" />

    <!-- Header -->
    <Rectangle id="hdr" width="1920" height="80" color="#111111" translation="[0,0]" />
    <Label id="titleLabel" text="BLOOD GLUCOSE VIEWER"
      translation="[60,22]" color="#FFFFFF" font="font:LargeBoldSystemFont" />
    <Label id="hdrSubtitle" text="SETUP"
      translation="[0,30]" width="1860" horizAlign="right"
      color="#666666" font="font:MediumSystemFont" />

    <!-- Post-setup instruction panel (shown after disclaimer/settings) -->
    <Rectangle id="setupPanel" width="1920" height="1080" color="#000000" visible="false">

      <!-- Orange accent bar -->
      <Rectangle id="setupAccent" width="1920" height="6" color="#FF6B00" translation="[0,80]" />

      <Label id="setupHeading"
        text="SETUP COMPLETE"
        translation="[0,180]" horizAlign="center"
        color="#FF6B00" font="font:LargeBoldSystemFont"
        width="1920" />

      <Label id="setupSummary"
        text=""
        translation="[260,270]"
        color="#CCCCCC" font="font:MediumSystemFont"
        width="1400" />

      <!-- Divider -->
      <Rectangle id="setupDivider" width="1400" height="2" color="#333333" translation="[260,360]" />

      <!-- Activation instructions -->
      <Label id="setupStepsLbl"
        text="TO VIEW YOUR DASHBOARD"
        translation="[260,390]"
        color="#888888" font="font:SmallBoldSystemFont"
        width="1400" />

      <Label id="setupStep1"
        text="1.  Press HOME on your Roku remote."
        translation="[260,440]"
        color="#FFFFFF" font="font:MediumSystemFont"
        width="1400" />

      <Label id="setupStep2"
        text="2.  Go to Settings  >  Screensaver  >  Change screensaver."
        translation="[260,490]"
        color="#FFFFFF" font="font:MediumSystemFont"
        width="1400" />

      <Label id="setupStep3"
        text="3.  Select &quot;Blood Glucose Viewer&quot; from the list."
        translation="[260,540]"
        color="#FFFFFF" font="font:MediumSystemFont"
        width="1400" />

      <Label id="setupStep4"
        text="4.  Your dashboard will appear automatically when your Roku is idle."
        translation="[260,590]"
        color="#FFFFFF" font="font:MediumSystemFont"
        width="1400" />

      <!-- Bottom divider -->
      <Rectangle id="setupDivider2" width="1400" height="2" color="#333333" translation="[260,670]" />

      <Label id="setupNote"
        text="You can return here any time from the Roku home screen to change accounts."
        translation="[260,700]"
        color="#888888" font="font:SmallSystemFont"
        width="1400" />

      <!-- Accounts summary (populated by MainScene.brs) -->
      <Label id="accountsTitle"
        text="CONFIGURED ACCOUNTS"
        translation="[260,770]"
        color="#888888" font="font:SmallBoldSystemFont"
        width="1400" visible="false" />

      <Label id="accountsList"
        text=""
        translation="[260,810]"
        color="#FFFFFF" font="font:MediumSystemFont"
        width="1400" visible="false" />

    </Rectangle>

    <!-- No-accounts panel: shown if user exits settings without configuring -->
    <Rectangle id="noAcctPanel" width="1920" height="1080" color="#000000" visible="false">
      <Rectangle width="1920" height="6" color="#FF6B00" translation="[0,80]" />
      <Label text="NO ACCOUNTS CONFIGURED"
        translation="[0,300]" horizAlign="center"
        color="#FF6B00" font="font:LargeBoldSystemFont"
        width="1920" />
      <Label text="Press OPTIONS to add a Nightscout or Dexcom account."
        translation="[0,400]" horizAlign="center"
        color="#FFFFFF" font="font:MediumSystemFont"
        width="1920" />
    </Rectangle>

    <!-- Settings scene (shown on demand) -->
    <SettingsScene id="settingsScene" visible="false" />

    <!-- Disclaimer scene (shown on first launch of this session) -->
    <DisclaimerScene id="disclaimerScene" visible="true" />

    <!-- Footer -->
    <Rectangle width="1920" height="1" color="#222222" translation="[0,1040]" />
    <Label text="OPTIONS = settings   BACK = exit"
      translation="[60,1052]" color="#2A2A2A" font="font:SmallestSystemFont" />
    <Label id="statusLabel" text=""
      translation="[0,1052]" width="1860" horizAlign="right"
      color="#2A2A2A" font="font:SmallestSystemFont" />

  </children>
</component>
